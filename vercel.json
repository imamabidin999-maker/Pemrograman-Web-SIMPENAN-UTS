{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/admin", "dest": "/api/admin/index" },
    { "src": "/admin/(.*\\.php)", "dest": "/api/admin/$1" },
    { "src": "/login", "dest": "/api/login" },
    { "src": "/register", "dest": "/api/register" },
    { "src": "/dashboard", "dest": "/api/dashboard" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/api/index" }
  ]
}